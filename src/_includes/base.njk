<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title or site.name }}</title>
    <meta name="description" content="{{ description or site.tagline }}">
    <link rel="icon" type="image/png" href="/docs-assets/logo.png">
    <link rel="apple-touch-icon" href="/docs-assets/logo.png">
    <link rel="stylesheet" href="/assets/styles.css">
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="shell site-header__inner">
        <a class="brand" href="/">
          <img class="brand__logo" src="/docs-assets/logo.png" alt="Everyone Deserves Housing logo">
          <span class="brand__text">{{ site.name }}</span>
        </a>
        <div class="site-header__actions">
          <nav class="site-nav" aria-label="Primary">
            <a href="#mission">Mission</a>
            <a href="#model">Model</a>
            <a href="#workflow">Workflow</a>
            <a href="#partners">Partners</a>
          </nav>
          <a class="header-contact" href="mailto:{{ home.contact.email }}">
            <img class="header-contact__icon" src="/docs-assets/email.svg" alt="" aria-hidden="true">
            <span>{{ home.contact.email }}</span>
          </a>
        </div>
      </div>
    </header>
    <main id="main">
      {{ content | safe }}
    </main>
  </body>
</html>
